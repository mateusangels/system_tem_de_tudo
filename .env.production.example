# ============================================================
# .env DE PRODUÇÃO — Hostinger (MySQL)
# Copie pra .env após clonar o repo no servidor.
# ============================================================

VITE_API_URL=""

APP_NAME="Tem de Tudo"
APP_ENV=production
APP_KEY=                         # gerar com `php artisan key:generate`
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://tem-de-tudo-sistema.angelsdev.tech

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning                # produção: warning/error pra não inundar log

# ─── MySQL Hostinger ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u831912804_tem_de_tudo
DB_USERNAME=u831912804_mateusangels1
DB_PASSWORD=Angels.3011@

# ─── Sessão / cache ──────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.angelsdev.tech    # cookie cobre subdomínios do domínio principal
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="naoresponder@temdetudo.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum: domínio de produção
SANCTUM_STATEFUL_DOMAINS=tem-de-tudo-sistema.angelsdev.tech

# Mensalidade e trial
MENSALIDADE_VALOR=180.00
TRIAL_DIAS=7
