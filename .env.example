# ============================================================
# Tem de Tudo — template de variáveis de ambiente
# Copie pra .env e ajuste pra cada ambiente (dev/produção).
# ============================================================

# ─── Frontend (Vite) ──────────────────────────────────────────
# Deixe vazio: o axios usa /api relativo → funciona em qualquer host
VITE_API_URL=""

# ─── Backend (Laravel) ────────────────────────────────────────
APP_NAME="Tem de Tudo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Banco ────────────────────────────────────────────────────
# DEV LOCAL: sqlite (cria arquivo em database/database.sqlite)
DB_CONNECTION=sqlite
# PRODUÇÃO HOSTINGER: troque pra mysql + dados do hPanel
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=u123_tem_de_tudo
# DB_USERNAME=u123_usuario
# DB_PASSWORD=

# ─── Sessão / cache ───────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="naoresponder@temdetudo.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum: domínios autorizados a manter sessão
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

# ─── Negócio ──────────────────────────────────────────────────
# Mensalidade do sistema cobrada do dono da loja (R$/mês)
MENSALIDADE_VALOR=180.00
# Dias de trial gratuito ao criar o usuário do dono
TRIAL_DIAS=7
